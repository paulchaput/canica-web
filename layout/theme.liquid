<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — Canica</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Space+Grotesk:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'canica.css' | asset_url | stylesheet_tag }}
</head>
<body>

  <div id="cursor"></div>
  <div id="cursor-dot"></div>

  <div class="fp-dots" id="fp-dots">
    <button class="fp-dot fp-dot--active" data-index="0" title="Inicio"></button>
    <button class="fp-dot" data-index="1" title="Concepto"></button>
    <button class="fp-dot" data-index="2" title="Membresías"></button>
    <button class="fp-dot" data-index="3" title="Café"></button>
    <button class="fp-dot" data-index="4" title="Eventos"></button>
    <button class="fp-dot" data-index="5" title="Reservar"></button>
  </div>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <a href="{{ routes.root_url }}">
      <img src="{{ 'logo-alt-black.png' | asset_url }}" alt="{{ shop.name }}" class="nav__logo-img" id="nav-logo">
    </a>
    <div class="nav__links">
      <a href="#s-memberships">Membresías</a>
      <a href="#s-cafe">Café</a>
      <a href="#s-events">Eventos</a>
      <a href="#s-cta" class="btn-nav">Reservar</a>
    </div>
    <button class="nav__burger" id="burger" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <div class="mobile-menu" id="mobile-menu">
    <a href="#s-memberships">Membresías</a>
    <a href="#s-cafe">Café</a>
    <a href="#s-events">Eventos</a>
    <a href="#s-cta">Reservar</a>
  </div>

  <main>
    {{ content_for_layout }}
  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
  {{ 'canica.js' | asset_url | script_tag }}

</body>
</html>
