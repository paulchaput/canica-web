<section class="s-cta" id="s-cta">
  <div class="s-cta__orb s-cta__orb--1" aria-hidden="true"></div>
  <div class="s-cta__orb s-cta__orb--2" aria-hidden="true"></div>
  <div class="s-cta__orb s-cta__orb--3" aria-hidden="true"></div>
  <div class="s-cta__inner reveal">
    <span class="eyebrow eyebrow--light">{{ section.settings.eyebrow }}</span>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>
    <div class="s-cta__btns">
      <a href="{{ section.settings.btn1_url }}" class="btn btn--white" target="_blank" rel="noopener">
        {{ section.settings.btn1_text }}
      </a>
      <a href="{{ section.settings.btn2_url }}" class="btn btn--ghost-white">
        {{ section.settings.btn2_text }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA / Reservar",
  "settings": [
    { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",           "default": "¿Listo para entrar?" },
    { "type": "text",     "id": "heading",  "label": "Título",            "default": "Tu primer visita te va a convencer." },
    { "type": "textarea", "id": "body",     "label": "Cuerpo",            "default": "Agenda una visita, únete a una membresía o reserva tu fiesta. Estamos en Havre 73." },
    { "type": "text",     "id": "btn1_text","label": "Botón 1 texto",     "default": "Escribir por WhatsApp" },
    { "type": "url",      "id": "btn1_url", "label": "Botón 1 link" },
    { "type": "text",     "id": "btn2_text","label": "Botón 2 texto",     "default": "Enviar un correo" },
    { "type": "url",      "id": "btn2_url", "label": "Botón 2 link" }
  ],
  "presets": [{ "name": "CTA" }]
}
{% endschema %}
