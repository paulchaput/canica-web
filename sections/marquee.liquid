<div class="s-marquee" aria-hidden="true">
  <div class="s-marquee__track">
    {% assign items = section.settings.text | split: '|' %}
    {% for item in items %}<span>{{ item | strip }}</span><span class="marquee-dot">●</span>{% endfor %}
    {% for item in items %}<span>{{ item | strip }}</span><span class="marquee-dot">●</span>{% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "text", "id": "text", "label": "Frases (separadas por |)", "default": "Un lugar para jugar|One place, two rhythms|Havre 73, CDMX|Un lugar para respirar|A place to play" }
  ],
  "presets": [{ "name": "Marquee" }]
}
{% endschema %}
