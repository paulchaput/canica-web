<section class="s-events" id="s-events">
  <div class="s-events__inner">
    <div class="s-events__header reveal">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="events-grid">
      {% for block in section.blocks %}
        <div class="event-card reveal" {{ block.shopify_attributes }}>
          <div class="event-card__visual event-card__visual--{{ forloop.index }}">
            <div class="poster-geo">
              <span style="width:50px;height:50px;background:{{ block.settings.color1 }};border-radius:{{ block.settings.shape1_round }}%;"></span>
              <span style="width:38px;height:38px;background:{{ block.settings.color2 }};border-radius:50%;"></span>
              <span style="width:44px;height:44px;background:{{ block.settings.color3 }};border-radius:0;"></span>
            </div>
            <div class="event-card__tag">{{ block.settings.tag }}</div>
          </div>
          <div class="event-card__body">
            <span class="event-card__type">{{ block.settings.type }}</span>
            <h4>{{ block.settings.title }}</h4>
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class="s-events__footer">
      <a href="{{ section.settings.cta_url }}" class="btn btn--outline">{{ section.settings.cta_text }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Eventos",
  "settings": [
    { "type": "text", "id": "eyebrow",  "label": "Eyebrow",  "default": "Talleres y Eventos" },
    { "type": "text", "id": "heading",  "label": "Título",   "default": "Siempre hay algo pasando." },
    { "type": "text", "id": "cta_text", "label": "Botón",    "default": "Ver todos los eventos" },
    { "type": "url",  "id": "cta_url",  "label": "Link botón" }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Evento",
      "settings": [
        { "type": "text",  "id": "tag",         "label": "Badge (fecha/estado)", "default": "Próximamente" },
        { "type": "text",  "id": "type",        "label": "Tipo",                 "default": "Taller Infantil" },
        { "type": "text",  "id": "title",       "label": "Título",               "default": "Taller de Cookies" },
        { "type": "text",  "id": "description", "label": "Descripción",          "default": "Hornear, decorar y comer." },
        { "type": "color", "id": "color1",      "label": "Color forma 1",        "default": "#D95A2B" },
        { "type": "color", "id": "color2",      "label": "Color forma 2",        "default": "#2A6B3C" },
        { "type": "color", "id": "color3",      "label": "Color forma 3",        "default": "#B5283C" },
        { "type": "range", "id": "shape1_round","label": "Redondez forma 1", "min": 0, "max": 50, "step": 50, "default": 0 }
      ]
    }
  ],
  "presets": [{
    "name": "Eventos",
    "blocks": [
      { "type": "event", "settings": { "type": "Taller Infantil", "title": "Taller de Cookies", "description": "Hornear, decorar y comer. El orden importa poco.", "color1": "#F2B435", "color2": "#D95A2B", "color3": "#2A6B3C" } },
      { "type": "event", "settings": { "type": "Para Padres",     "title": "Arte y Maternidad", "description": "Charla con artistas sobre creatividad y vida con hijos.", "color1": "#7B9FD4", "color2": "#C86B7A", "color3": "#F2B435", "shape1_round": 50 } },
      { "type": "event", "settings": { "tag": "Reservar", "type": "Fiesta Privada", "title": "Fiestas Canica", "description": "El espacio completo para ti.", "color1": "#F5F0E8", "color2": "#F2B435", "color3": "#D95A2B", "shape1_round": 50 } }
    ]
  }]
}
{% endschema %}
