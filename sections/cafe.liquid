<section class="s-cafe" id="s-cafe">
  <div class="s-cafe__inner">
    <div class="s-cafe__text reveal reveal--left">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.body }}</p>
      <a href="{{ section.settings.cta_url }}" class="btn btn--primary">{{ section.settings.cta_text }}</a>
    </div>
    <div class="menu-card reveal reveal--right">
      {% for i in (1..3) %}
        {% assign cat_key   = 'cat' | append: i | append: '_name' %}
        {% assign items_key = 'cat' | append: i | append: '_items' %}
        {% assign cat_name  = section.settings[cat_key] %}
        {% assign cat_items = section.settings[items_key] | split: '|' %}
        {% if cat_name != blank %}
          <div class="menu-category">
            <h4>{{ cat_name }}</h4>
            {% for row in cat_items %}
              {% assign parts = row | split: ':' %}
              <div class="menu-item">
                <span>{{ parts[0] | strip }}</span>
                <span>{{ parts[1] | strip }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Café",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",   "default": "El Café" },
    { "type": "text",     "id": "heading",    "label": "Título",    "default": "Buen café. Buenos momentos." },
    { "type": "textarea", "id": "body",       "label": "Cuerpo",    "default": "Selección de especialidad..." },
    { "type": "text",     "id": "cta_text",   "label": "Botón",     "default": "Reservar mesa" },
    { "type": "url",      "id": "cta_url",    "label": "Link botón" },
    { "type": "header",   "content": "Categoría 1" },
    { "type": "text",     "id": "cat1_name",  "label": "Nombre",    "default": "Café" },
    { "type": "text",     "id": "cat1_items", "label": "Items (Nombre:Precio separados por |)", "default": "Espresso:$55|Cappuccino:$70|Latte de la casa:$75|Matcha latte:$80" },
    { "type": "header",   "content": "Categoría 2" },
    { "type": "text",     "id": "cat2_name",  "label": "Nombre",    "default": "Desayunos" },
    { "type": "text",     "id": "cat2_items", "label": "Items (Nombre:Precio separados por |)", "default": "Tostada con aguacate:$115|Bowl de granola:$95|Huevos revueltos:$130" },
    { "type": "header",   "content": "Categoría 3" },
    { "type": "text",     "id": "cat3_name",  "label": "Nombre",    "default": "Para ellos" },
    { "type": "text",     "id": "cat3_items", "label": "Items (Nombre:Precio separados por |)", "default": "Leche con cacao:$45|Galleta Canica:$35|Jugo del día:$55" }
  ],
  "presets": [{ "name": "Café" }]
}
{% endschema %}
